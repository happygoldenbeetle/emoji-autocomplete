<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="EmojiTyper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EmojiTyper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Emoji Typer"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Emoji Typer">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <StackPanel
            Grid.Row="1"
            Margin="24"
            Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Running — the hook is active system-wide" />
            </StackPanel>

            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap">
                Type a colon followed by an emoji name in <Bold>any</Bold> app — for example
                <Bold>:sob:</Bold> → 😭 or <Bold>:fire:</Bold> → 🔥. A suggestion list appears
                as you type; use ↑/↓ then Enter or Tab to pick, or finish the name and type the
                closing colon.
            </TextBlock>

            <TextBox
                x:Name="TestBox"
                Header="Try it here (or anywhere else):"
                PlaceholderText="Type :sob:"
                AcceptsReturn="True"
                Height="120"
                TextWrapping="Wrap" />

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                TextWrapping="Wrap"
                Text="Closing this window hides it to the system tray — Emoji Typer keeps running. Right-click the tray icon and choose Exit to quit." />
        </StackPanel>
    </Grid>
</Window>
